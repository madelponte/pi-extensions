{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enabled": { "type": "boolean", "default": true },
    "prefix": { "type": "string", "pattern": "^[A-Za-z0-9_]*$", "default": "mcp" },
    "disabledTools": { "type": "array", "items": { "type": "string" }, "default": [] },
    "allowedTools": { "type": "array", "items": { "type": "string" }, "default": [] },
    "server": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "command"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "stdio" },
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" }, "default": [] },
            "cwd": { "type": "string" },
            "env": { "type": "object", "additionalProperties": { "type": "string" }, "default": {} }
          }
        },
        {
          "type": "object",
          "required": ["type", "url"],
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["sse", "http"] },
            "url": { "type": "string" },
            "headers": { "type": "object", "additionalProperties": { "type": "string" }, "default": {} }
          }
        }
      ]
    }
  },
  "required": ["server"]
}
